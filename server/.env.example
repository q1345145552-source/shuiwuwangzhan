# ========== 数据库配置 ==========
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_NAME=thai_tax_db

# ========== 服务端口 ==========
PORT=3007

# ========== JWT 认证 ==========
JWT_SECRET=替换为随机强密钥（至少 64 位随机字符）
JWT_EXPIRES_IN=24h

# 注意：AUTH_USERNAME / AUTH_PASSWORD 已废弃
# 用户管理已迁移到数据库 users 表，登录不再读取这两个环境变量

# ========== 认证开关 ==========
# 生产环境务必设为 false
SKIP_AUTH=false

# ========== 备份目录 ==========
BACKUP_DIR=/Users/你的用户名/thai-tax-backups

# ========== CORS 白名单 ==========
# 逗号分隔多个域名，生产环境填实际域名
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
