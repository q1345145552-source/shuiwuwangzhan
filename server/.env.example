# ========== 数据库配置 ==========
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_NAME=thai_tax_db

# ========== 服务端口 ==========
PORT=3007

# ========== JWT 认证（必填）==========
JWT_SECRET=替换为你的随机密钥
JWT_EXPIRES_IN=24h
AUTH_USERNAME=admin
# AUTH_PASSWORD 必须是 bcrypt 加密后的哈希值
# 生成方法：node -e "require('bcryptjs').hash('你的密码',10).then(console.log)"
AUTH_PASSWORD=

# ========== 认证开关 ==========
# 生产环境务必设为 false
SKIP_AUTH=false

# ========== 备份目录 ==========
BACKUP_DIR=/Users/你的用户名/thai-tax-backups
